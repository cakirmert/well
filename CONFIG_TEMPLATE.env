# Copy this file to .env and fill in values locally.
# Do not share .env and do not commit it if this becomes a git repo.

TIMEZONE=Europe/Berlin

# Email source.
# - graph: Outlook.com / Microsoft 365 through Microsoft Graph OAuth.
# - imap: Gmail, iCloud Mail, Yahoo, Fastmail, or a custom IMAP mailbox.
# - outlook: classic Windows desktop Outlook COM integration.
EMAIL_PROVIDER=graph
IMAP_PROVIDER=auto
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=your-email@example.com
# Leave blank to read from the OS keychain / credential store via:
#   python -m wellpass_sync set-secret IMAP_PASSWORD
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# Microsoft Graph email source. Recommended for Outlook.com / new Outlook.
# Leave GRAPH_CLIENT_ID blank to use Microsoft's public "Microsoft Graph
# Command Line Tools" client. Set it only if you later create your own app.
GRAPH_CLIENT_ID=
GRAPH_TENANT=consumers
GRAPH_SCOPES=Mail.Read
GRAPH_TOKEN_CACHE=data/graph-token-cache.json

# Google Gmail / Calendar OAuth. Create a Desktop OAuth client in Google Cloud
# and point this to the downloaded JSON file.
GOOGLE_CLIENT_SECRETS_PATH=google-oauth-client.json
GOOGLE_TOKEN_CACHE=data/google-token-cache.json

# Search filters. These should be adjusted after seeing real emails.
EMAIL_SENDER_HINTS=Wellpass,noreply-de@egym-wellpass.com
EMAIL_SUBJECT_HINTS=booking,reservation,buchung,storniert,cancelled,cancellation
EMAIL_BODY_HINTS=wellpass,egym
SEARCH_SINCE_DAYS=30
IMAP_MAX_MESSAGES=100

# Calendar target. Options: icloud_caldav, google_calendar,
# outlook_calendar, ics.
CALENDAR_PROVIDER=icloud_caldav
CALENDAR_NAME=Wellpass
CALDAV_URL=https://caldav.icloud.com
ICLOUD_USERNAME=your-apple-id@example.com
# Optional comma-separated reminder minutes before start. Leave blank to let
# calendar defaults/user preferences handle alerts.
CALENDAR_REMINDER_MINUTES=
# Leave blank to read from the OS keychain / credential store via:
#   python -m wellpass_sync set-secret ICLOUD_APP_PASSWORD
ICLOUD_APP_PASSWORD=

# Fallback if CalDAV is unavailable or for local testing.
ICS_EXPORT_DIR=exports

# Safety.
DRY_RUN=true
DATABASE_PATH=data/wellpass-sync.sqlite

# Scheduling defaults. Uses Task Scheduler on Windows, LaunchAgent on macOS,
# and a systemd user timer on Linux.
TASK_NAME=Wellpass Calendar Sync
TASK_INTERVAL_MINUTES=30
